# --- Flight Meetup Finder configuration -------------------------------------

# HTTP port the FastAPI app listens on (host-side; container port stays 8000).
APP_PORT=8742

# SQLite file location inside the container. Mapped to ./data on the host.
DATABASE_URL=sqlite:////data/fmf.db

# fast-flights fetch mode. Only "local" (Playwright + Chromium) currently works
# reliably as of 2026-06; "fallback" requires a turnstile token, "common"
# hits Google's consent page. See ARCHITECTURE.md.
FETCH_MODE=local

# Throttle between scrape queries (seconds). Random jitter ±30% is applied.
SCRAPE_DELAY_SECONDS=1.5

# Rough duration of one uncached scrape (seconds) — only used to estimate
# how long a search will take in the UI.
SCRAPE_COST_SECONDS=6.0

# Hard ceiling on a single scrape (seconds). A hung Playwright/Chromium call
# fails-soft via the retry path instead of wedging the single worker forever.
SCRAPE_TIMEOUT_SECONDS=90.0

# How many distinct legs to scrape at once within a job. Each scrape is a full
# headless Chromium (~300-500 MB) hitting Google, so keep this small: too high
# risks host RAM pressure and CAPTCHA/turnstile from Google. 2 is conservative.
SCRAPE_CONCURRENCY=2

# Cache TTL for a single (origin, destination, date) raw result, in hours.
CACHE_TTL_HOURS=12

# Static EUR -> GBP rate for combined price display.
EUR_TO_GBP=0.85

# Fixed travellers (used as display labels, not for auth).
TRAVELLER_A_NAME=Lucas
TRAVELLER_A_ORIGIN=MAN
TRAVELLER_B_NAME=Talita
TRAVELLER_B_ORIGINS=LIS,OPO,FAO
